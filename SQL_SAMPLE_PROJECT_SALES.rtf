\outl0\strokewidth0 \strokec2 CREATE TABLE customers (\
customer_id INT PRIMARY KEY,\
name VARCHAR(50),\
city VARCHAR(50)\
);\
\
CREATE TABLE orders (\
    order_id INT PRIMARY KEY,\
    customer_id INT,\
    order_date DATE,\
    total_amount INT,\
    FOREIGN KEY (customer_id) REFERENCES customers(customer_id)\
);\
\
CREATE TABLE products (\
product_id VARCHAR(10) PRIMARY KEY,\
name VARCHAR(50),\
category VARCHAR(50),\
price INT\
);\
